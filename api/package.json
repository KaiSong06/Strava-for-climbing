{
  "name": "@crux/api",
  "version": "0.0.1",
  "description": "Crux backend API",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "worker:vision": "ts-node-dev --respawn --transpile-only src/jobs/visionWorker.ts",
    "worker:retirement": "ts-node-dev --respawn --transpile-only src/jobs/retirementJob.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "migrate": "node -r ts-node/register scripts/migrate.ts",
    "db:migrate": "node -r ts-node/register scripts/migrate.ts",
    "db:seed": "node -r ts-node/register scripts/seed.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "@types/multer": "^2.1.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.11.5",
    "pgvector": "^0.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
