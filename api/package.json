{
  "name": "@crux/api",
  "version": "0.0.1",
  "description": "Crux backend API",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "worker:vision": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/jobs/visionWorker.ts",
    "worker:retirement": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/jobs/retirementJob.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/api/src/index.js",
    "test": "jest",
    "migrate": "node -r ts-node/register -r tsconfig-paths/register scripts/migrate.ts",
    "db:migrate": "node -r ts-node/register -r tsconfig-paths/register scripts/migrate.ts",
    "db:seed": "node -r ts-node/register -r tsconfig-paths/register scripts/seed.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@sentry/node": "^10.45.0",
    "@supabase/supabase-js": "^2.99.3",
    "@types/multer": "^2.1.0",
    "bullmq": "^5.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "jose": "^6.2.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.11.5",
    "pgvector": "^0.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.0"
  }
}
